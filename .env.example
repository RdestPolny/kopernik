# Skopiuj ten plik do `.env` i uzupełnij wartości. `.env` jest w .gitignore — nie trafi do repo.
# Aplikacja wczytuje .env automatycznie przy starcie.

# --- Wymagane (istniejące) ---
FIRECRAWL_KEY=
GEMINI_KEY=

# --- Senuto API (widoczność w AI Overviews) ---
# Wariant A: gotowy token z POST /api/users/token (ważny ~30 dni, trzeba odświeżać ręcznie)
SENUTO_BEARER_TOKEN=

# Wariant B (zalecany): logowanie automatyczne — aplikacja sama odświeża token
SENUTO_EMAIL=
SENUTO_PASSWORD=

# Opcjonalne
SENUTO_COUNTRY_ID=200
# SENUTO_API_BASE=https://api.senuto.com/api

# --- Opcjonalne integracje (jeśli używane) ---
# PAGESPEED_KEY=
# PERPLEXITY_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=
# GEMINI_MODEL=gemini-3.1-flash-lite

# --- OpenAI / ChatGPT (sekcja "Jak Cię widzą LLM-y") ---
# Jeśli ChatGPT zwraca 429 "insufficient_quota" — konto OpenAI nie ma kredytów/billingu.
# Kod ma retry/backoff na chwilowy rate-limit (429) i fallback modeli, ale wyczerpanego
# limitu konta nie obejdzie — wtedy doładuj billing w OpenAI.
# GPT_KEY=
# GPT_MODEL=gpt-4o-mini
# GPT_FALLBACK_MODELS=gpt-4o-mini,gpt-3.5-turbo

# --- Przechowywanie raportów (udostępnianie linkiem + przywoływanie domeny) ---
# Raporty zapisują się w pamięci procesu zawsze; ustaw FIRESTORE_PROJECT, by przetrwały
# restart i działały między instancjami (kolekcja `reports`, klucz = domena).
# FIRESTORE_PROJECT=
