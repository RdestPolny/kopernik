# Skopiuj ten plik do `.env` i uzupełnij wartości. `.env` jest w .gitignore — nie trafi do repo.
# Aplikacja wczytuje .env automatycznie przy starcie.

# --- Wymagane (istniejące) ---
FIRECRAWL_KEY=
GEMINI_KEY=

# --- Senuto API (widoczność w AI Overviews) ---
# Wariant A: gotowy token z POST /api/users/token (ważny ~30 dni, trzeba odświeżać ręcznie)
SENUTO_BEARER_TOKEN=

# Wariant B (zalecany): logowanie automatyczne — aplikacja sama odświeża token
SENUTO_EMAIL=
SENUTO_PASSWORD=

# Opcjonalne
SENUTO_COUNTRY_ID=200
# SENUTO_API_BASE=https://api.senuto.com/api

# --- Opcjonalne integracje (jeśli używane) ---
# PAGESPEED_KEY=
# PERPLEXITY_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=
# GEMINI_MODEL=gemini-3.1-flash-lite

# --- OpenAI / ChatGPT (sekcja "Jak Cię widzą LLM-y") ---
# Domyślnie używamy modelu z WYSZUKIWANIEM W SIECI (gpt-4o-search-preview), żeby ChatGPT
# rozpoznawał też niszowe firmy spoza danych treningowych (jak realny ChatGPT z web search).
# Jeśli ChatGPT zwraca 429 "insufficient_quota" — konto OpenAI nie ma kredytów/billingu.
# Kod ma retry/backoff na chwilowy rate-limit (429) i fallback modeli.
# GPT_KEY=
# GPT_MODEL=gpt-4o-search-preview
# GPT_FALLBACK_MODELS=gpt-4o-mini-search-preview,gpt-4o,gpt-4o-mini

# --- Przechowywanie raportów (udostępnianie linkiem + przywoływanie domeny) ---
# Raporty zapisują się w pamięci procesu zawsze; ustaw FIRESTORE_PROJECT, by przetrwały
# restart i działały między instancjami (kolekcje `reports`, `leads`, `lead_emails`).
# FIRESTORE_PROJECT=

# --- Komercyjne API v1 ---
# Produkcyjne organizacje i hashe kluczy są przechowywane w kolekcjach Firestore
# `organizations` oraz `api_keys`. Poniższa zmienna służy tylko do local/dev i również
# powinna zawierać wyłącznie hash SHA-256, nigdy pełny klucz.
# KOPERNIK_API_KEY_RECORDS=[{"key_id":"...","key_hash":"...","organization_id":"...","environment":"test","scopes":["audits:create","audits:read"],"revoked":false}]
KOPERNIK_API_KEY_CACHE_TTL=15
AUDIT_MAX_CONCURRENT=4
AUDIT_JOBS_MEMORY_MAX=1000
AUDIT_JOB_MEMORY_TTL=86400
LEGACY_MAX_ACTIVE=2

# --- Pozyskiwanie leadów (bramka mailowa) ---
# Powiadomienia o leadach trafiają na LEADS_EMAIL (domyślnie marcin.zielinski@strategiczni.pl).
# Użytkownik po podaniu maila dostaje na SWÓJ adres link do odblokowanego raportu.
# Wysyłka maili wymaga danych SMTP (np. Gmail App Password).
# LEADS_EMAIL=marcin.zielinski@strategiczni.pl
# SMTP_USER=
# SMTP_PASS=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# LEADS_TOKEN=            # zabezpiecza GET /leads?token=...
# Publiczny adres bazowy (bez końcowego /) do budowy linku w mailu:
# PUBLIC_BASE_URL=https://strategiczni.ai/llms-audit
