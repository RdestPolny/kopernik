+// ─── Markdown renderer ────────────────────────────────────────────────────
+// Block-aware: tables / headings / lists / hr / fenced code / paragraphs.
+// Inline pass runs INSIDE table cells too, so `**bold**` and `*italic*` work
+// in headers and rows. Italic regex requires non-space adjacent so it cannot
+// hijack list bullets like `*   Action:*` across spans.
+function escapeHtml(s: string): string {
+    return s
+        .replace(/&/g, '&amp;')
+        .replace(/</g, '&lt;')
+        .replace(/>/g, '&gt;')
+        .replace(/"/g, '&quot;');
+}
+
+function applyInline(s: string): string {
+    let out = s;
+    // inline code first so its body isn't touched by bold/italic
+    out = out.replace(/`([^`\n]+)`/g, '<code class="bg-surface-container-low px-1.5 py-0.5 rounded text-blue-300 font-mono text-xs border border-outline-variant/30">$1</code>');
+    // bold — non-space adjacent, single line
+    out = out.replace(/\*\*([^\s*][^*\n]*?[^\s*]|\S)\*\*/g, '<strong class="text-on-surface font-semibold">$1</strong>');
+    // italic — must be preceded by start or non-`*`, non-space adjacent inside
+    out = out.replace(/(^|[^*\w])\*([^\s*][^*\n]*?[^\s*]|\S)\*(?!\*)/g, '$1<em class="italic text-outline">$2</em>');
+    // links [text](url)
+    out = out.replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer" class="text-blue-400 underline hover:text-blue-300">$1</a>');
+    return out;
+}
+
+function renderTableBlock(block: string): string {
+    const lines = block.trim().split('\n').filter(l => l.trim());
+    if (lines.length < 2) return `<p class="my-3 text-on-surface-variant leading-relaxed">${applyInline(escapeHtml(block))}</p>`;
+    const isSeparator = (l: string) => /^\s*\|?[\s\-:|]+\|?\s*$/.test(l) && /-/.test(l);
+    const sepIdx = lines.findIndex(isSeparator);
+    if (sepIdx < 1) return `<p class="my-3 text-on-surface-variant leading-relaxed">${applyInline(escapeHtml(block))}</p>`;
+    const splitRow = (r: string) => r.replace(/^\s*\|/, '').replace(/\|\s*$/, '').split('|').map(c => c.trim());
+    const headers = splitRow(lines[sepIdx - 1]);
+    const rows = lines.slice(sepIdx + 1).map(splitRow);
+    const fmt = (c: string) => applyInline(escapeHtml(c));
+    const headerHtml = headers.map(h =>
+        `<th class="px-3 py-2 text-left text-xs font-bold text-on-surface-variant uppercase tracking-wider border-b border-outline-variant/50 bg-surface-container/60">${fmt(h)}</th>`
+    ).join('');
+    const rowsHtml = rows.map((cells, ri) => {
+        const rowBg = ri % 2 === 0 ? '' : 'bg-surface-container-low/40';
+        return `<tr class="border-b border-outline-variant/30 hover:bg-surface-container-low transition-colors ${rowBg}">${cells.map(c =>
+            `<td class="px-3 py-2 text-sm text-on-surface-variant align-top">${fmt(c)}</td>`
+        ).join('')}</tr>`;
+    }).join('');
+    return `<div class="overflow-x-auto my-4 rounded-sm border border-outline-variant/30"><table class="w-full text-sm border-collapse bg-surface-container-low/40"><thead><tr>${headerHtml}</tr></thead><tbody>${rowsHtml}</tbody></table></div>`;
+}
+
+const isUnorderedItem = (l: string) => /^\s*[*\-+]\s+/.test(l) && !/^\s*\*\*/.test(l);
+const isOrderedItem = (l: string) => /^\s*\d+\.\s+/.test(l);
+const isHr = (l: string) => /^\s*-{3,}\s*$/.test(l) || /^\s*\*{3,}\s*$/.test(l) || /^\s*_{3,}\s*$/.test(l);
+const isBlockStart = (l: string) =>
+    /^#{1,3}\s/.test(l) || isUnorderedItem(l) || isOrderedItem(l) || isHr(l) || /^\x00TBL\d+\x00/.test(l) || /^\s*```/.test(l);
+
+function renderMarkdown(text: string): string {
+    let src = (text || '').replace(/\r\n/g, '\n');
+
+    // Extract fenced code blocks first so nothing inside is reinterpreted.
+    const codeBlocks: string[] = [];
+    src = src.replace(/```[a-zA-Z0-9]*\n?([\s\S]*?)```/g, (_match, body) => {
+        codeBlocks.push(`<pre class="bg-surface-container-low p-3 rounded-sm my-3 overflow-x-auto text-xs text-blue-200 border border-outline-variant/30"><code>${escapeHtml(body.replace(/\n$/, ''))}</code></pre>`);
+        return `\x00CODE${codeBlocks.length - 1}\x00`;
+    });
+
+    // Extract tables (consecutive pipe-prefixed lines that contain a separator row).
+    const tables: string[] = [];
+    src = src.replace(/(?:^[ \t]*\|.*\n?){2,}/gm, (match) => {
+        if (!/\n[\s|\-:]+/.test(match)) return match; // not a table — leave alone
+        tables.push(renderTableBlock(match));
+        return `\x00TBL${tables.length - 1}\x00\n`;
+    });
+
+    const lines = src.split('\n');
+    const out: string[] = [];
+    let i = 0;
+
+    while (i < lines.length) {
+        const line = lines[i];
+
+        // Placeholder lines pass through untouched.
+        const codeMatch = line.match(/^\s*\x00CODE(\d+)\x00\s*$/);
+        if (codeMatch) { out.push(codeBlocks[parseInt(codeMatch[1])]); i++; continue; }
+        const tblMatch = line.match(/^\s*\x00TBL(\d+)\x00\s*$/);
+        if (tblMatch) { out.push(tables[parseInt(tblMatch[1])]); i++; continue; }
+
+        if (/^### /.test(line)) { out.push(`<h3 class="text-lg font-bold text-on-surface-variant mt-4 mb-2">${applyInline(escapeHtml(line.slice(4)))}</h3>`); i++; continue; }
+        if (/^## /.test(line))  { out.push(`<h2 class="text-xl font-bold text-on-surface mt-5 mb-3">${applyInline(escapeHtml(line.slice(3)))}</h2>`); i++; continue; }
+        if (/^# /.test(line))   { out.push(`<h1 class="text-2xl font-bold text-on-surface mt-6 mb-4">${applyInline(escapeHtml(line.slice(2)))}</h1>`); i++; continue; }
 
+        if (isHr(line)) { out.push('<hr class="my-4 border-outline-variant/30"/>'); i++; continue; }
+
+        if (isUnorderedItem(line)) {
+            const items: string[] = [];
+            while (i < lines.length && isUnorderedItem(lines[i])) {
+                items.push(lines[i].replace(/^\s*[*\-+]\s+/, '').replace(/^\[ \]\s*/, '☐ ').replace(/^\[x\]\s*/i, '☑ '));
+                i++;
+            }
+            out.push(`<ul class="list-disc ml-6 marker:text-tertiary my-3 space-y-1">${items.map(it => `<li class="text-on-surface-variant leading-relaxed">${applyInline(escapeHtml(it))}</li>`).join('')}</ul>`);
+            continue;
+        }
+
+        if (isOrderedItem(line)) {
+            const items: string[] = [];
+            while (i < lines.length && isOrderedItem(lines[i])) {
+                items.push(lines[i].replace(/^\s*\d+\.\s+/, ''));
+                i++;
+            }
+            out.push(`<ol class="list-decimal ml-6 marker:text-emerald-400 my-3 space-y-1">${items.map(it => `<li class="text-on-surface-variant leading-relaxed">${applyInline(escapeHtml(it))}</li>`).join('')}</ol>`);
+            continue;
+        }
+
+        // Blank line — paragraph break.
+        if (line.trim() === '') { i++; continue; }
+
+        // Collect a paragraph until a block starter or blank line.
+        const para: string[] = [];
+        while (i < lines.length && lines[i].trim() !== '' && !isBlockStart(lines[i])) {
+            para.push(lines[i]);
+            i++;
+        }
+        if (para.length > 0) {
+            const inner = para.map(p => applyInline(escapeHtml(p))).join('<br/>');
+            out.push(`<p class="my-3 text-on-surface-variant leading-relaxed">${inner}</p>`);
+        }
+    }
+
+    return out.join('\n');
+}
